    "group": "extended"
  },
  "ba": {
    "label": "ば conditional",
    "description": "If-form built with ば.",
    "englishTemplate": "if [someone] [base meaning]",
    "enabledByDefault": false,
    "group": "extended"
  },
  "tara": {
    "label": "たら conditional",
    "description": "If/when/after-form built from the past + ら.",
    "englishTemplate": "if/when [someone] [base meaning] / after [someone] [base meaning]",
    "enabledByDefault": false,
    "group": "extended"
  },
  "imperative": {
    "label": "Imperative",
    "description": "Direct command. Hide by default.",
    "englishTemplate": "[base meaning]!",
